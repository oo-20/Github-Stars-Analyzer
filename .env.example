# GitHub Stars Analyzer 配置示例
# 复制此文件为 .env 并填入你的密钥

# GitHub OAuth App 配置（用于从网页端登录并 Star 仓库）
# 在 https://github.com/settings/developers 创建 OAuth App
# Homepage URL: http://localhost:5000
# Authorization callback URL: http://localhost:5000/api/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub 个人访问令牌（用于数据抓取）
# 在 https://github.com/settings/tokens 创建，无需任何权限（public repos only）
GITHUB_TOKEN=your_github_token
